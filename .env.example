# Used by docker-compose.yml. Copy to .env and fill in.

# Generate with: cd backend && php artisan key:generate --show
APP_KEY=

# Chat agents (/chat and /admin/chat): OpenRouter is the primary provider,
# OpenAI is the automatic failover when OpenRouter is rate-limited, out of
# credits, or overloaded. Set both keys.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
# Optional — only if you switch a provider to anthropic.
ANTHROPIC_API_KEY=

# Optional overrides for the chat provider chain (defaults shown).
# The primary model must support tool calling — pick from
# https://openrouter.ai/models?supported_parameters=tools
#AI_CHAT_PROVIDER=openrouter
#AI_CHAT_MODEL=google/gemma-4-31b-it:free
#AI_CHAT_FALLBACK_PROVIDER=openai
#AI_CHAT_FALLBACK_MODEL=       # empty = OpenAI's default model

# Optional — local Postgres password (defaults to ecom-local-pw).
#DB_PASSWORD=
